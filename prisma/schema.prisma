// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Asset {
  id           String         @id @default(cuid())
  symbol       String
  name         String
  type         AssetType
  broker       Broker
  quantity     Float
  avgCost      Float?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  priceHistory PriceHistory[]
  alerts       Alert[]

  @@unique([symbol, broker])
  @@index([symbol])
  @@index([broker])
}

model PriceHistory {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  price     Float
  currency  String   @default("USD")
  timestamp DateTime @default(now())
  source    String   @default("massive")

  @@index([assetId, timestamp])
  @@index([timestamp])
}

model PortfolioSnapshot {
  id          String   @id @default(cuid())
  totalValue  Float
  cashValue   Float
  cryptoValue Float
  stockValue  Float
  timestamp   DateTime @default(now())

  @@index([timestamp])
}

model Alert {
  id        String    @id @default(cuid())
  assetId   String
  asset     Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  type      AlertType
  threshold Float
  triggered Boolean   @default(false)
  createdAt DateTime  @default(now())

  @@index([assetId])
  @@index([triggered])
}

enum AssetType {
  CASH
  STABLECOIN
  CRYPTO
  STOCK
  ETF
}

enum Broker {
  CASH
  BINANCE
  IB
  FUTU
}

enum AlertType {
  ABOVE
  BELOW
  PCT_CHANGE
}

enum TransactionAction {
  BUY
  SELL
}

model Transaction {
  id          String            @id @default(cuid())
  date        DateTime
  ticker      String
  action      TransactionAction
  quantity    Float
  price       Float
  totalValue  Float
  fee         Float             @default(0)
  feeCcy      String            @default("USD")
  realizedPnL Float?
  broker      Broker
  notes       String?
  createdAt   DateTime          @default(now())

  @@index([ticker])
  @@index([date])
  @@index([broker])
  @@index([action])
}
